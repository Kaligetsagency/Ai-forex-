{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@signal-scanner/types": ["../../packages/types/src"],
      "@signal-scanner/database": ["../../packages/database/src/index"]
    }
  },
  "include": ["src/**/*"]
}
